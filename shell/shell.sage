## shell/shell.sage — SageOS-RV Interactive Echo Shell

print("SageOS-RV Shell — interactive echo\n\n")

print("sage# ")
let c1 = readline()
print("You typed: ")
print(c1)
print("\n")

print("sage# ")
let c2 = readline()
print("You typed: ")
print(c2)
print("\n")

print("sage# ")
let c3 = readline()
print("You typed: ")
print(c3)
print("\n")

print("Shell done.\n")
