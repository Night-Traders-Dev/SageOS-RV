print("I2C Bus Driver — DesignWare I2C\n")
print("\n")
print("  I2C0: 0x04000000\n")
print("  I2C1: 0x04010000\n")
print("  I2C2: 0x04020000\n")
print("  I2C3: 0x04030000\n")
print("  Speed: 100 kHz (standard mode)\n")
print("\n")
print("Usage:\n")
print("  i2c scan [bus]     — scan for devices\n")
print("  i2c read <addr> <reg> <len>\n")
print("  i2c write <addr> <reg> <val>\n")
