print("Watchdog — DesignWare WDT @ 0x03010000\n")
print("\n")
print("  Timeout: ~1.3 seconds (TORR=12)\n")
print("  Mode:    Reset on timeout\n")
print("  Kicked:  every ~1 second by RTOS scheduler\n")
print("  Panic:   stops kicking → auto-reset\n")
print("\n")
print("Usage:\n")
print("  wdog status\n")
print("  wdog kick\n")
print("  wdog enable|disable\n")
