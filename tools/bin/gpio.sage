print("GPIO Driver — DesignWare GPIO (4 banks)\n")
print("\n")
print("  GPIO0: 0x03020000 (32 pins)\n")
print("  GPIO1: 0x03021000 (32 pins)\n")
print("  GPIO2: 0x03022000 (32 pins)\n")
print("  GPIO3: 0x03023000 (32 pins)\n")
print("  LED:   GPIO0 pin 14 (active low)\n")
print("\n")
print("Usage:\n")
print("  gpio read <bank> <pin>\n")
print("  gpio write <bank> <pin> <0|1>\n")
print("  gpio mode <bank> <pin> <in|out>\n")
print("  gpio led on|off|toggle\n")
