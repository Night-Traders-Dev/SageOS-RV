#!/usr/bin/env bash
set -euo pipefail

## sagemake - SageOS-RV build system
## Usage: ./sagemake <command> [options]
##
## Commands:
##   build           Compile boot, kernel, and produce OS image
##   clean           Remove all build artifacts
##   qemu            Run OS in QEMU emulator
##   build-run       Build then run in QEMU
##   image           Generate disk image
##   flash           Flash image to SD card (requires device path)
##   test            Run test suite
##   bench           Run benchmarks
##   version         Show version info
##   compile-kernel  Compile kernel/kmain.sage -> kernel/kmain.sgvm
##   run-kernel      Run kernel/kmain.sgvm via sagevm
##   compile-shell   Compile shell/shell.sage -> shell/shell.sgvm
##   run-shell       Run shell/shell.sgvm via sagevm
##   setup-srvm      Copy SRVM Sage sources from SageVM repo into kernel/
##   help            Show this help

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/config/build.conf"

## Try multiple locations for SageLang compiler
SAGE="${SAGE:-}"
if [ -z "$SAGE" ]; then
    for candidate in \
        /home/kraken/Devel/SageLang/core/build/sage \
        /home/kraken/Devel/SageLang/core/sage \
        sage \
        sage3; do
        if command -v "$candidate" >/dev/null 2>&1 || [ -x "$candidate" ]; then
            SAGE="$candidate"
            break
        fi
    done
fi
SAGE="${SAGE:-sage}"

## Try multiple locations for SageVM binary
SAGEVM="${SAGEVM:-}"
if [ -z "$SAGEVM" ]; then
    for candidate in \
        sagevm \
        /home/kraken/Devel/SageVM/sagevm \
        /home/kraken/Devel/SageLang/sagevm \
        "${SCRIPT_DIR}/../SageVM/sagevm"; do
        if command -v "$candidate" >/dev/null 2>&1 || [ -x "$candidate" ]; then
            SAGEVM="$candidate"
            break
        fi
    done
fi
SAGEVM="${SAGEVM:-sagevm}"

CC="${RISCV_CC:-riscv64-linux-gnu-gcc}"
LD="${RISCV_LD:-riscv64-linux-gnu-ld}"
OBJCOPY="${RISCV_OBJCOPY:-riscv64-linux-gnu-objcopy}"
QEMU="${QEMU_BIN:-qemu-system-riscv64}"
OPENSBI="${OPENSBI_FW:-/usr/lib/riscv64-linux-gnu/opensbi/generic/fw_dynamic.bin}"

SAGEVM_DIR="${SAGEVM_DIR:-${SCRIPT_DIR}/../SageVM}"

ARCH="rv64"
BOARD="${BOARD:-qemu-virt}"
BUILD_DIR="${SCRIPT_DIR}/build"
IMAGE_DIR="${SCRIPT_DIR}/images"

## Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
DIM='\033[0;90m'
BOLD='\033[1m'
RESET='\033[0m'

info()  { printf "${CYAN}  [INFO]${RESET} %s\n" "$1"; }
ok()    { printf "${GREEN}  [OK]${RESET}   %s\n" "$1"; }
warn()  { printf "${YELLOW}  [WARN]${RESET} %s\n" "$1"; }
fail()  { printf "${RED}  [FAIL]${RESET} %s\n" "$1"; exit 1; }

## ---------------------------------------------------------------------------
## sagevm_check: return 0 if sagevm is usable, 1 otherwise
## ---------------------------------------------------------------------------
sagevm_check() {
    command -v "$SAGEVM" >/dev/null 2>&1 || [ -x "$SAGEVM" ]
}

## ---------------------------------------------------------------------------
## compile_kernel_sgvm
## ---------------------------------------------------------------------------
## sagevm compile kernel/kmain.sage kernel/kmain.sgvm --riscv
## Skips gracefully if sagevm not found or compilation fails.
## ---------------------------------------------------------------------------
compile_kernel_sgvm() {
    local src="${SCRIPT_DIR}/kernel/kmain.sage"
    local out="${SCRIPT_DIR}/kernel/kmain.sgvm"

    if [ ! -f "${src}" ]; then
        warn "kernel/kmain.sage not found - skipping kmain.sgvm compilation"
        return
    fi

    if ! sagevm_check; then
        warn "sagevm not found (SAGEVM=${SAGEVM}) - skipping kmain.sgvm compilation"
        return
    fi

    info "Compiling kernel/kmain.sage -> kernel/kmain.sgvm ..."
    if "$SAGEVM" compile "${src}" "${out}" --riscv 2>&1; then
        ok "kmain.sgvm ($(wc -c < "${out}") bytes)"
    else
        warn "sagevm compile kernel failed - C transpile path will be used"
    fi
}

## ---------------------------------------------------------------------------
## compile_shell_sgvm
## ---------------------------------------------------------------------------
## sagevm compile shell/shell.sage shell/shell.sgvm --riscv
## ---------------------------------------------------------------------------
compile_shell_sgvm() {
    local src="${SCRIPT_DIR}/shell/shell.sage"
    local out="${SCRIPT_DIR}/shell/shell.sgvm"

    if [ ! -f "${src}" ]; then
        warn "shell/shell.sage not found - skipping shell.sgvm compilation"
        return
    fi

    if ! sagevm_check; then
        warn "sagevm not found (SAGEVM=${SAGEVM}) - skipping shell.sgvm compilation"
        warn "  To compile manually: sagevm compile shell/shell.sage shell/shell.sgvm --riscv"
        return
    fi

    info "Compiling shell/shell.sage -> shell/shell.sgvm ..."
    if "$SAGEVM" compile "${src}" "${out}" --riscv 2>&1; then
        ok "shell.sgvm ($(wc -c < "${out}") bytes)"
    else
        warn "sagevm compile shell failed - using existing shell.sgvm if present"
    fi
}

## ---------------------------------------------------------------------------
## embed_shell_sgvm
## ---------------------------------------------------------------------------
embed_shell_sgvm() {
    local sgvm_src="${SCRIPT_DIR}/shell/shell.sgvm"
    local sgvm_obj="${BUILD_DIR}/shell_sgvm.o"

    if [ ! -f "${sgvm_src}" ]; then
        warn "shell/shell.sgvm not found - built-in shell fallback will be used"
        printf '\0' | $OBJCOPY \
            -I binary -O elf64-littleriscv \
            --rename-section .data=.sgvm_shell \
            --set-section-flags .sgvm_shell=alloc,load,readonly \
            /dev/stdin "${sgvm_obj}" 2>/dev/null || true
        echo "${sgvm_obj}"
        return
    fi

    info "Embedding shell/shell.sgvm ($(wc -c < "${sgvm_src}") bytes)..."
    $OBJCOPY \
        -I binary \
        -O elf64-littleriscv \
        -B riscv \
        --rename-section .data=.sgvm_shell \
        --set-section-flags .sgvm_shell=alloc,load,readonly \
        "${sgvm_src}" "${sgvm_obj}" \
        && ok "shell_sgvm.o embedded" \
        || warn "objcopy failed - built-in shell fallback will be used"

    echo "${sgvm_obj}"
}

cmd_ensure_srvm() {
    local srvm_src="${SAGEVM_DIR}/src/srvm"
    local kernel_dir="${SCRIPT_DIR}/kernel"

    if [ -f "${kernel_dir}/srvm_core.sage" ] && [ -f "${kernel_dir}/srvm_vm.sage" ]; then
        return 0
    fi

    if [ -d "${srvm_src}" ]; then
        info "Copying SRVM sources from ${srvm_src}..."
        cp "${srvm_src}/srvm_core.sage" "${kernel_dir}/srvm_core.sage"
        cp "${srvm_src}/srvm_vm.sage"   "${kernel_dir}/srvm_vm.sage"
        ok "SRVM sources staged in kernel/"
    else
        warn "SAGEVM_DIR not found (${SAGEVM_DIR}). Set SAGEVM_DIR or run './sagemake setup-srvm'."
        warn "SRVM will be unavailable; kernel will compile without VM support."
    fi
}

cmd_setup_srvm() {
    local srvm_src="${SAGEVM_DIR}/src/srvm"
    if [ ! -d "${srvm_src}" ]; then
        fail "SageVM not found at ${SAGEVM_DIR}. Set SAGEVM_DIR=/path/to/SageVM"
    fi
    info "Staging SRVM sources from ${srvm_src} into kernel/..."
    cp "${srvm_src}/srvm_core.sage" "${SCRIPT_DIR}/kernel/srvm_core.sage"
    cp "${srvm_src}/srvm_vm.sage"   "${SCRIPT_DIR}/kernel/srvm_vm.sage"
    ok "kernel/srvm_core.sage"
    ok "kernel/srvm_vm.sage"
    info "Run: git add kernel/srvm_core.sage kernel/srvm_vm.sage && git commit"
}

## ---------------------------------------------------------------------------
## Standalone compile/run commands
## ---------------------------------------------------------------------------
cmd_compile_kernel() {
    compile_kernel_sgvm
}

cmd_run_kernel() {
    local sgvm="${SCRIPT_DIR}/kernel/kmain.sgvm"
    if [ ! -f "${sgvm}" ]; then
        fail "kernel/kmain.sgvm not found. Run './sagemake compile-kernel' first."
    fi
    if ! sagevm_check; then
        fail "sagevm not found (SAGEVM=${SAGEVM})."
    fi
    printf "\n${BOLD}  Running kmain.sgvm via sagevm${RESET}\n"
    printf "  ${DIM}%s${RESET}\n\n" "${sgvm}"
    "$SAGEVM" run "${sgvm}"
}

cmd_compile_shell() {
    mkdir -p "${SCRIPT_DIR}/shell"
    compile_shell_sgvm
}

cmd_run_shell() {
    local sgvm="${SCRIPT_DIR}/shell/shell.sgvm"
    if [ ! -f "${sgvm}" ]; then
        fail "shell/shell.sgvm not found. Run './sagemake compile-shell' first."
    fi
    if ! sagevm_check; then
        fail "sagevm not found (SAGEVM=${SAGEVM})."
    fi
    printf "\n${BOLD}  Running shell.sgvm via sagevm${RESET}\n"
    printf "  ${DIM}%s${RESET}\n\n" "${sgvm}"
    "$SAGEVM" run "${sgvm}"
}

cmd_build() {
    printf "\n${BOLD}  SageOS-RV Build${RESET}\n"
    printf "  ${DIM}Board: %s | Arch: %s${RESET}\n\n" "$BOARD" "$ARCH"

    mkdir -p "$BUILD_DIR" "$IMAGE_DIR"

    ## Ensure SRVM Sage sources are in kernel/
    cmd_ensure_srvm

    ## Step 1: Generate boot assembly from Sage
    info "Generating boot assembly from Sage..."
    if ! $SAGE --emit-c "${SCRIPT_DIR}/boot/start.sage" -o "${BUILD_DIR}/boot_generated.c" 2>/dev/null; then
        warn "Sage boot emit failed, using fallback C"
    fi

    ## Step 2: Compile RISC-V boot assembly
    info "Compiling RISC-V boot assembly..."
    $CC -march=rv64imac_zicsr_zifencei -mabi=lp64 -nostdlib -ffreestanding \
        -c "${SCRIPT_DIR}/boot/arch/rv64/boot.S" \
        -o "${BUILD_DIR}/boot.o" || fail "Boot assembly compilation failed"

    ## Step 3a: Compile kernel/kmain.sage -> kmain.sgvm
    compile_kernel_sgvm

    ## Step 3b: Compile shell/shell.sage -> shell.sgvm
    compile_shell_sgvm

    ## Step 3c: Convert shell.sgvm -> linkable ELF object
    local sgvm_obj
    sgvm_obj=$(embed_shell_sgvm)

    ## Step 3d: Transpile kernel Sage -> C (fallback / C linker path)
    info "Compiling kernel from Sage to C..."
    if ! $SAGE --emit-c "${SCRIPT_DIR}/kernel/kmain.sage" -o "${BUILD_DIR}/kernel.c" 2>/dev/null; then
        warn "Sage kernel emit failed, using fallback"
        cp "${SCRIPT_DIR}/kernel/fallback_kernel.c" "${BUILD_DIR}/kernel.c" 2>/dev/null || true
    fi

    info "Compiling kernel C to object..."
    $CC -march=rv64imac_zicsr_zifencei -mabi=lp64 -nostdlib -ffreestanding -O2 \
        -I"${SCRIPT_DIR}/kernel" \
        -DCONFIG_BOARD=\"${BOARD}\" \
        -c "${BUILD_DIR}/kernel.c" \
        -o "${BUILD_DIR}/kernel.o" 2>&1 || warn "Kernel C compilation had issues"

    info "Compiling DTB parser..."
    $CC -march=rv64imac_zicsr_zifencei -mabi=lp64 -nostdlib -ffreestanding -O2 \
        -I"${SCRIPT_DIR}/kernel" \
        -c "${SCRIPT_DIR}/kernel/dtb.c" \
        -o "${BUILD_DIR}/dtb.o" 2>&1 || fail "DTB compilation failed"

    info "Compiling VMM..."
    $CC -march=rv64imac_zicsr_zifencei -mabi=lp64 -nostdlib -ffreestanding -O2 \
        -I"${SCRIPT_DIR}/kernel" \
        -c "${SCRIPT_DIR}/kernel/vmm.c" \
        -o "${BUILD_DIR}/vmm.o" 2>&1 || fail "VMM compilation failed"

    ## Step 4: Compile drivers
    info "Compiling drivers..."
    for sage_file in "${SCRIPT_DIR}"/drivers/*.sage; do
        [ -f "$sage_file" ] || continue
        local name
        name=$(basename "$sage_file" .sage)
        if $SAGE --emit-c "$sage_file" -o "${BUILD_DIR}/drv_${name}.c" 2>/dev/null; then
            $CC -march=rv64imac_zicsr_zifencei -mabi=lp64 -nostdlib -ffreestanding -O2 \
                -c "${BUILD_DIR}/drv_${name}.c" -o "${BUILD_DIR}/drv_${name}.o" 2>/dev/null \
                && ok "Driver: $name" || warn "Driver: $name (partial)"
        fi
    done

    ## Step 5: Link
    info "Linking kernel image..."
    local link_script="${SCRIPT_DIR}/boot/arch/rv64/linker.ld"
    local drv_objs=()
    for f in "${BUILD_DIR}"/drv_*.o; do
        [ -f "$f" ] && drv_objs+=("$f")
    done

    local extra_objs=()
    [ -f "${sgvm_obj}" ] && extra_objs+=("${sgvm_obj}")

    $LD -T "$link_script" -nostdlib \
        "${BUILD_DIR}/boot.o" \
        "${BUILD_DIR}/kernel.o" \
        "${BUILD_DIR}/dtb.o" \
        "${BUILD_DIR}/vmm.o" \
        "${extra_objs[@]}" \
        "${drv_objs[@]}" \
        -o "${BUILD_DIR}/sageos.elf" 2>&1 \
        && ok "Linked sageos.elf" || warn "Link had issues (expected for alpha)"

    ## Step 6: Create binary
    if [ -f "${BUILD_DIR}/sageos.elf" ]; then
        $OBJCOPY -O binary "${BUILD_DIR}/sageos.elf" "${IMAGE_DIR}/sageos.bin"
        ok "Created sageos.bin"
    fi

    ## Report modes
    if [ -f "${SCRIPT_DIR}/kernel/kmain.sgvm" ]; then
        ok "Kernel mode: kmain.sgvm ($(wc -c < "${SCRIPT_DIR}/kernel/kmain.sgvm") bytes, MetalVM)"
    else
        warn "Kernel mode: C transpile only (kmain.sgvm not built)"
    fi
    if [ -f "${SCRIPT_DIR}/shell/shell.sgvm" ]; then
        ok "Shell mode:  shell.sgvm ($(wc -c < "${SCRIPT_DIR}/shell/shell.sgvm") bytes, SRVM)"
    else
        warn "Shell mode:  built-in fallback"
    fi

    printf "\n  ${DIM}Build complete.${RESET}\n\n"
}

cmd_clean() {
    info "Cleaning build artifacts..."
    rm -rf "$BUILD_DIR"
    rm -f "$IMAGE_DIR"/sageos.bin "$IMAGE_DIR"/sageos.elf
    ok "Clean"
}

cmd_qemu() {
    info "Launching QEMU (RISC-V 64 virt)..."
    local kernel_bin="${IMAGE_DIR}/sageos.bin"
    local kernel_elf="${BUILD_DIR}/sageos.elf"

    if [ -f "$kernel_elf" ]; then
        kernel_arg="-kernel $kernel_elf"
    elif [ -f "$kernel_bin" ]; then
        kernel_arg="-kernel $kernel_bin"
    else
        fail "No kernel image found. Run './sagemake build' first."
    fi

    $QEMU \
        -machine virt \
        -cpu rv64 \
        -smp 1 \
        -m 128M \
        -nographic \
        -bios "$OPENSBI" \
        $kernel_arg \
        -serial mon:stdio 2>&1 || true
}

cmd_build_run() {
    cmd_build
    cmd_qemu
}

cmd_image() {
    info "Generating disk image..."
    mkdir -p "$IMAGE_DIR"
    if [ -f "${IMAGE_DIR}/sageos.bin" ]; then
        dd if=/dev/zero of="${IMAGE_DIR}/sageos.img" bs=1M count=64 2>/dev/null
        ok "Created 64MB disk image (sageos.img)"
    else
        fail "No kernel binary found. Run './sagemake build' first."
    fi
}

cmd_test() {
    info "Running test suite..."
    for test_file in "${SCRIPT_DIR}"/tests/*.sage; do
        [ -f "$test_file" ] || continue
        local name
        name=$(basename "$test_file")
        printf "  ${CYAN}%-30s${RESET}" "$name"
        if $SAGE --runtime ast "$test_file" > /dev/null 2>&1; then
            printf "${GREEN}PASS${RESET}\n"
        else
            printf "${RED}FAIL${RESET}\n"
        fi
    done
}

cmd_version() {
    local ver
    ver=$(cat "${SCRIPT_DIR}/VERSION" 2>/dev/null || echo "unknown")
    printf "SageOS-RV version %s\n" "$ver"
    printf "Board: %s\n" "$BOARD"
    printf "Arch: %s\n" "$ARCH"
    $SAGE --version 2>/dev/null || true
    "$SAGEVM" --version 2>/dev/null || true
    $QEMU --version 2>/dev/null | head -1 || true
}

cmd_help() {
    sed -n '2,/^$/p' "$0" | sed 's/^## \?//'
}

case "${1:-help}" in
    build)           cmd_build ;;
    clean)           cmd_clean ;;
    qemu)            cmd_qemu ;;
    build-run)       cmd_build_run ;;
    image)           cmd_image ;;
    test)            cmd_test ;;
    version)         cmd_version ;;
    compile-kernel)  cmd_compile_kernel ;;
    run-kernel)      cmd_run_kernel ;;
    compile-shell)   cmd_compile_shell ;;
    run-shell)       cmd_run_shell ;;
    setup-srvm)      cmd_setup_srvm ;;
    help|--help|-h)  cmd_help ;;
    *)               echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac
