#!/usr/bin/env bash
set -euo pipefail

## sagemake - SageOS-RV build system
## Usage: ./sagemake <command> [options]
##

## Commands:
##   build           Compile boot, kernel blobs, RTOS, MetalVM; link OS image
##   clean           Remove all build artifacts
##   qemu            Run OS in QEMU emulator
##   build-run       Build then run in QEMU
##   image           Generate disk image
##   test            Run test suite
##   version         Show version info
##   compile-kernel  Compile kernel/core/kmain.sage -> kernel/core/kmain.sgvm
##   run-kernel      Run kernel/core/kmain.sgvm via sagevm
##   compile-shell   Compile shell/shell.sage -> shell/shell.sgvm
##   run-shell       Run shell/shell.sgvm via sagevm
##   setup-srvm      Copy SRVM Sage sources from SageVM repo into kernel/
##   setup-metalvm   Validate MetalVM headers in kernel/ (does NOT overwrite them)
##   setup-rtos      Clone rtos/SageRTOS (idempotent)
##   mermaid-graphics Generate README.md Mermaid diagrams as PNGs (mobile-friendly graphics)
##   help            Show this help

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/config/build.conf"

## SageLang compiler / VM
SAGE="${SAGE:-}"
if [ -z "$SAGE" ]; then
    # Try system binaries in PATH first
    for candidate in sage sage3; do
        if command -v "$candidate" >/dev/null 2>&1 || [ -x "$candidate" ]; then
            SAGE="$candidate"; break
        fi
    done
fi
if [ -z "$SAGE" ]; then
    # Fallback to internal development versions
    for candidate in \
        /home/kraken/Devel/sagelang/core/build/sage \
        /home/kraken/Devel/sagelang/core/sage \
        /home/kraken/Devel/SageLang/core/build/sage \
        /home/kraken/Devel/SageLang/core/sage; do
        if [ -x "$candidate" ]; then
            SAGE="$candidate"; break
        fi
    done
fi
SAGE="${SAGE:-sage}"

SAGEVM="${SAGEVM:-}"
if [ -z "$SAGEVM" ]; then
    # Try system binaries in PATH first
    if command -v sagevm >/dev/null 2>&1; then
        SAGEVM="sagevm"
    fi
fi
if [ -z "$SAGEVM" ]; then
    # Fallback to internal development versions
    for candidate in \
        /home/kraken/Devel/SageVM/sagevm \
        /home/kraken/Devel/sagelang/sagevm \
        /home/kraken/Devel/SageLang/sagevm \
        "${SCRIPT_DIR}/../SageVM/sagevm" \
        "${SCRIPT_DIR}/../SageLang/sagevm"; do
        if [ -x "$candidate" ]; then
            SAGEVM="$candidate"; break
        fi
    done
fi
SAGEVM="${SAGEVM:-sagevm}"

CC="${RISCV_CC:-riscv64-linux-gnu-gcc}"
LD="${RISCV_LD:-riscv64-linux-gnu-ld}"
OBJCOPY="${RISCV_OBJCOPY:-riscv64-linux-gnu-objcopy}"
QEMU="${QEMU_BIN:-qemu-system-riscv64}"
OPENSBI="${OPENSBI_FW:-/usr/lib/riscv64-linux-gnu/opensbi/generic/fw_dynamic.bin}"

SAGEVM_DIR="${SAGEVM_DIR:-${SCRIPT_DIR}/deps/SageVM}"

## Resolve SAGELANG_CORE — prefer lowercase path (actual checkout location)
if [ -z "${SAGELANG_CORE:-}" ]; then
    for candidate in \
        "/home/kraken/Devel/sagelang/core" \
        "${SCRIPT_DIR}/deps/sagelang/core" \
        "${SCRIPT_DIR}/../sagelang/core" \
        "/home/kraken/Devel/SageLang/core" \
        "${SCRIPT_DIR}/../SageLang/core"; do
        if [ -d "$candidate" ]; then
            SAGELANG_CORE="$candidate"; break
        fi
    done
fi
SAGELANG_CORE="${SAGELANG_CORE:-${SCRIPT_DIR}/../sagelang/core}"

RTOS_DIR="${SCRIPT_DIR}/rtos/SageRTOS"
SAGERTOS_REPO="https://github.com/Night-Traders-Dev/SageRTOS.git"

ARCH="rv64"
BOARD="${BOARD:-qemu-virt}"
BUILD_DIR="${SCRIPT_DIR}/build"
IMAGE_DIR="${SCRIPT_DIR}/images"

## MetalVM include path — use upstream sagelang headers, kernel for impl
METAL_INC="${SAGELANG_CORE}/include"
KERNEL_INC="${SCRIPT_DIR}/kernel"
KERNEL_VM="${SCRIPT_DIR}/kernel/vm"
KERNEL_HW="${SCRIPT_DIR}/kernel/hw"
KERNEL_SRVM="${SCRIPT_DIR}/kernel/srvm"
KERNEL_CORE="${SCRIPT_DIR}/kernel/core"

## Bare-metal compile flags
BM_CFLAGS="${BM_ARCH} -nostdlib -ffreestanding -O2"
BM_DEFS="-DSAGE_BARE_METAL -DSAGE_METAL_VM -DUART_BASE=${UART_BASE} -DCONFIG_MEM_BASE=${QEMU_MEM_BASE} -DCONFIG_TIMER_FREQ=${TIMER_FREQ} ${BM_EXTRA_DEFS:-}"
## SageVM optional layer
if [ "${SAGEVM_ENABLED:-0}" = "1" ]; then
    BM_DEFS="$BM_DEFS -DCONFIG_SAGEVM"
fi

## Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
YELLOW='\033[1;33m'; DIM='\033[0;90m'; BOLD='\033[1m'; RESET='\033[0m'
info() { printf "${CYAN}  [INFO]${RESET} %s\n" "$1" >&2; }
ok()   { printf "${GREEN}  [OK]${RESET}   %s\n" "$1" >&2; }
warn() { printf "${YELLOW}  [WARN]${RESET} %s\n" "$1" >&2; }
fail() { printf "${RED}  [FAIL]${RESET} %s\n" "$1" >&2; exit 1; }

sagevm_check() { command -v "$SAGEVM" >/dev/null 2>&1 || [ -x "$SAGEVM" ]; }

metal_headers_present() {
    [ -f "${SCRIPT_DIR}/kernel/vm/metal_vm.h" ] && \
    [ -f "${SCRIPT_DIR}/kernel/vm/metal_rv64_vm.h" ]
}

metal_impl_present() {
    [ -f "${SCRIPT_DIR}/kernel/vm/metal_vm_impl.c" ] && \
    [ -f "${SCRIPT_DIR}/kernel/vm/metal_rv64_vm_impl.c" ]
}

## ---------------------------------------------------------------------------
## setup-metalvm
##
## kernel/vm/metal_vm.h and kernel/vm/metal_rv64_vm.h are committed kernel-local
## files (bare-metal Q32.32 variants). This command validates they are
## present and that impl files exist.  It deliberately does NOT overwrite
## committed headers with the upstream hosted (double-based) versions.
##
## Only copies from SAGELANG_CORE as a last-resort recovery if the file is
## genuinely missing from the working tree.
## ---------------------------------------------------------------------------
cmd_setup_metalvm() {
    local inc="${SAGELANG_CORE}/include"

    # metal_vm.h — use committed kernel-local file; do NOT overwrite
    if [ -f "${SCRIPT_DIR}/kernel/vm/metal_vm.h" ]; then
        ok "kernel/vm/metal_vm.h"
    elif [ -f "${inc}/metal_vm.h" ]; then
        warn "kernel/vm/metal_vm.h missing — falling back to upstream copy (bare-metal guards apply via -DSAGE_BARE_METAL)"
        cp "${inc}/metal_vm.h" "${SCRIPT_DIR}/kernel/vm/metal_vm.h"
        ok "kernel/vm/metal_vm.h (copied from upstream)"
    else
        fail "kernel/vm/metal_vm.h not found in kernel/ or ${inc}"
    fi

    # metal_rv64_vm.h — same policy
    if [ -f "${SCRIPT_DIR}/kernel/vm/metal_rv64_vm.h" ]; then
        ok "kernel/vm/metal_rv64_vm.h"
    elif [ -f "${inc}/metal_rv64_vm.h" ]; then
        warn "kernel/vm/metal_rv64_vm.h missing — falling back to upstream copy"
        cp "${inc}/metal_rv64_vm.h" "${SCRIPT_DIR}/kernel/vm/metal_rv64_vm.h"
        ok "kernel/vm/metal_rv64_vm.h (copied from upstream)"
    else
        fail "kernel/vm/metal_rv64_vm.h not found in kernel/ or ${inc}"
    fi

    metal_impl_present || fail "MetalVM impl files missing: kernel/vm/metal_vm_impl.c and/or kernel/vm/metal_rv64_vm_impl.c"

    ok "MetalVM ready.  Build with: ./sagemake build"
}

## ---------------------------------------------------------------------------
## RTOS helpers
## ---------------------------------------------------------------------------
rtos_available() { [ -f "${RTOS_DIR}/src/rv64/sagertos_rv64.c" ]; }

cmd_setup_rtos() {
    mkdir -p "${SCRIPT_DIR}/rtos"
    if [ -d "${RTOS_DIR}/.git" ]; then
        ok "rtos/SageRTOS already present ($(git -C "${RTOS_DIR}" rev-parse --short HEAD 2>/dev/null || echo '?'))"
        return
    fi
    [ -d "${RTOS_DIR}" ] && rm -rf "${RTOS_DIR}"
    info "Cloning SageRTOS..."
    git clone --depth=1 --branch main "$SAGERTOS_REPO" "${RTOS_DIR}" \
        && ok "SageRTOS cloned" || fail "Clone failed: ${SAGERTOS_REPO}"
    rtos_available \
        && ok "SageRTOS ready: ${RTOS_DIR}" \
        || warn "Cloned but sagertos_rv64.c not found -- check repo structure"
}

compile_rtos() {
    if ! rtos_available; then
        warn "SageRTOS not found -- skipping (run ./sagemake setup-rtos)"
        return
    fi
    info "Compiling SageRTOS RV64 (sagertos_rv64.c)..."
    $CC $BM_CFLAGS $BM_DEFS -DSAGE_RTOS \
        -I"${RTOS_DIR}/src/rv64" \
        -c "${RTOS_DIR}/src/rv64/sagertos_rv64.c" \
        -o "${BUILD_DIR}/sagertos_rv64.o" \
        && ok "sagertos_rv64.o" || warn "sagertos_rv64.c compile had warnings"
    info "Compiling SageRTOS RV64 ASM (sagertos_rv64_asm.S)..."
    $CC $BM_CFLAGS -I"${RTOS_DIR}/src/rv64" \
        -c "${RTOS_DIR}/src/rv64/sagertos_rv64_asm.S" \
        -o "${BUILD_DIR}/sagertos_rv64_asm.o" \
        && ok "sagertos_rv64_asm.o" || warn "asm compile had warnings"
    info "Compiling RTOS glue (rtos/sagertos_glue.c)..."
    $CC $BM_CFLAGS $BM_DEFS -DSAGE_RTOS \
        -I"${RTOS_DIR}/src/rv64" -I"${SCRIPT_DIR}/kernel" \
        -c "${SCRIPT_DIR}/rtos/sagertos_glue.c" \
        -o "${BUILD_DIR}/sagertos_glue.o" \
        && ok "sagertos_glue.o" || warn "glue compile had warnings"
}

## ---------------------------------------------------------------------------
## compile_metalvm
## ---------------------------------------------------------------------------
compile_metalvm() {
    metal_impl_present || fail "MetalVM impl files not found in kernel/.\n  Expected: kernel/vm/metal_vm_impl.c and/or kernel/vm/metal_rv64_vm_impl.c"

    METAL_OBJS=()

    info "Compiling MetalVM (metal_vm_impl.c)..."
    $CC $BM_CFLAGS $BM_DEFS \
        -I"${METAL_INC}" \
        -c "${SCRIPT_DIR}/kernel/vm/metal_vm_impl.c" \
        -o "${BUILD_DIR}/metal_vm_impl.o" \
        && ok "metal_vm_impl.o" || fail "MetalVM metal_vm_impl.c compile failed"
    METAL_OBJS+=("${BUILD_DIR}/metal_vm_impl.o")

    info "Compiling MetalVM RV64 backend (metal_rv64_vm_impl.c)..."
    $CC $BM_CFLAGS $BM_DEFS \
        -I"${METAL_INC}" \
        -c "${SCRIPT_DIR}/kernel/vm/metal_rv64_vm_impl.c" \
        -o "${BUILD_DIR}/metal_rv64_vm_impl.o" \
        && ok "metal_rv64_vm_impl.o" || fail "MetalVM metal_rv64_vm_impl.c compile failed"
    METAL_OBJS+=("${BUILD_DIR}/metal_rv64_vm_impl.o")
}

## ---------------------------------------------------------------------------
## sgvm compile helpers
## ---------------------------------------------------------------------------
compile_kernel_sgvm() {
    if [ "${SAGEVM_ENABLED:-0}" != "1" ]; then
        warn "SageVM disabled — skipping kernel .sgvm compilation"
        return 0
    fi
    local src="${SCRIPT_DIR}/kernel/core/kmain.sage"
    local out="${SCRIPT_DIR}/kernel/core/kmain.sgvm"
    [ -f "${src}" ] || fail "kernel/core/kmain.sage not found"
    sagevm_check || fail "sagevm not found -- cannot compile kmain.sgvm"
    info "Compiling kernel/core/kmain.sage -> kernel/core/kmain.sgvm ..."
    "$SAGEVM" compile "${src}" "${out}" --riscv 2>&1 \
        && ok "kmain.sgvm ($(wc -c < "${out}") bytes)" \
        || fail "kmain.sage compilation failed"
}

compile_shell_sgvm() {
    if [ "${SAGEVM_ENABLED:-0}" != "1" ]; then
        warn "SageVM disabled — skipping shell .sgvm compilation"
        return 0
    fi
    local src="${SCRIPT_DIR}/shell/shell.sage"
    local out="${SCRIPT_DIR}/shell/shell.sgvm"
    [ -f "${src}" ] || fail "shell/shell.sage not found"
    sagevm_check || fail "sagevm not found -- cannot compile shell.sgvm"
    info "Compiling shell/shell.sage -> shell/shell.sgvm ..."
    "$SAGEVM" compile "${src}" "${out}" --riscv 2>&1 \
        && ok "shell.sgvm ($(wc -c < "${out}") bytes)" \
        || fail "shell/shell.sage compilation failed"
}

embed_kernel_sgvm() {
    local src="kernel/core/kmain.sgvm"
    local obj="${BUILD_DIR}/kernel_sgvm.o"
    [ -f "${SCRIPT_DIR}/${src}" ] || fail "embed_kernel_sgvm: ${SCRIPT_DIR}/${src} missing"
    local bsz; bsz=$(wc -c < "${SCRIPT_DIR}/${src}")
    info "Embedding kernel/core/kmain.sgvm (${bsz} bytes) -> .sgvm_kernel section"
    ( cd "${SCRIPT_DIR}" && \
      $OBJCOPY \
        -I binary -O elf64-littleriscv -B riscv \
        --rename-section .data=.sgvm_kernel \
        --set-section-flags .sgvm_kernel=alloc,load,readonly \
        "${src}" "${obj}" ) \
        && ok "kernel_sgvm.o embedded" \
        || fail "objcopy embed failed for kmain.sgvm"
    echo "${obj}"
}

embed_shell_sgvm() {
    local src="shell/shell.sgvm"
    local obj="${BUILD_DIR}/shell_sgvm.o"
    [ -f "${SCRIPT_DIR}/${src}" ] || fail "embed_shell_sgvm: ${SCRIPT_DIR}/${src} missing"
    local bsz; bsz=$(wc -c < "${SCRIPT_DIR}/${src}")
    info "Embedding shell/shell.sgvm (${bsz} bytes) -> .sgvm_shell section"
    ( cd "${SCRIPT_DIR}" && \
      $OBJCOPY \
        -I binary -O elf64-littleriscv -B riscv \
        --rename-section .data=.sgvm_shell \
        --set-section-flags .sgvm_shell=alloc,load,readonly \
        "${src}" "${obj}" ) \
        && ok "shell_sgvm.o embedded" \
        || fail "objcopy embed failed for shell.sgvm"
    echo "${obj}"
}

cmd_ensure_srvm() {
    local srvm_src="${SAGEVM_DIR}/src/srvm"
    local kdir="${SCRIPT_DIR}/kernel/srvm"
    [ -f "${kdir}/srvm_core.sage" ] && [ -f "${kdir}/srvm_vm.sage" ] && return 0
    if [ -d "${srvm_src}" ]; then
        info "Copying SRVM sources..."
        cp "${srvm_src}/srvm_core.sage" "${kdir}/srvm_core.sage"
        cp "${srvm_src}/srvm_vm.sage"   "${kdir}/srvm_vm.sage"
        ok "SRVM staged in kernel/srvm/"
    else
        warn "SAGEVM_DIR not found (${SAGEVM_DIR}). Set SAGEVM_DIR or run './sagemake setup-srvm'."
    fi
}

cmd_setup_srvm() {
    local srvm_src="${SAGEVM_DIR}/src/srvm"
    if [ ! -d "${srvm_src}" ]; then
        info "Cloning SageVM submodule..."
        git submodule update --init --recursive deps/SageVM || fail "Submodule init failed"
    fi
    [ -d "${srvm_src}" ] || fail "SageVM submodule not found at ${SAGEVM_DIR}. Run: git submodule update --init"
    cp "${srvm_src}/srvm_core.sage" "${SCRIPT_DIR}/kernel/srvm/srvm_core.sage"
    cp "${srvm_src}/srvm_vm.sage"   "${SCRIPT_DIR}/kernel/srvm/srvm_vm.sage"
    ok "kernel/srvm/srvm_core.sage"; ok "kernel/srvm/srvm_vm.sage"
}

cmd_compile_kernel() { compile_kernel_sgvm; }
cmd_run_kernel() {
    local sgvm="${SCRIPT_DIR}/kernel/core/kmain.sgvm"
    [ -f "${sgvm}" ] || fail "kernel/core/kmain.sgvm not found."
    sagevm_check || fail "sagevm not found."
    "$SAGEVM" run "${sgvm}" --riscv
}
cmd_compile_shell() { mkdir -p "${SCRIPT_DIR}/shell"; compile_shell_sgvm; }
cmd_run_shell() {
    local sgvm="${SCRIPT_DIR}/shell/shell.sgvm"
    [ -f "${sgvm}" ] || fail "shell/shell.sgvm not found."
    sagevm_check || fail "sagevm not found."
    "$SAGEVM" run "${sgvm}" --riscv
}

## ---------------------------------------------------------------------------
## cmd_build
## ---------------------------------------------------------------------------
cmd_build() {
    printf "\n${BOLD}  SageOS-RV Build${RESET}\n" >&2
    printf "  ${DIM}Board: %s | Arch: %s${RESET}\n\n" "$BOARD" "$ARCH" >&2
    mkdir -p "$BUILD_DIR" "$IMAGE_DIR"

    metal_headers_present || fail "MetalVM headers not found in kernel/.\n  Run: ./sagemake setup-metalvm"
    metal_impl_present    || fail "MetalVM impl files not found in kernel/.\n  Expected: metal_vm_impl.c + metal_rv64_vm_impl.c"

    cmd_ensure_srvm

    ## 0. Build SageBoot (Unified Bootloader)
    info "Compiling SageBoot..."
    if [ -d "${SCRIPT_DIR}/bootloader" ] && [ -f "${SCRIPT_DIR}/bootloader/Makefile" ]; then
        ( cd "${SCRIPT_DIR}/bootloader" && SAGE_COMPILER="$SAGE" make ARCH="$ARCH" ) >/dev/null 2>&1 \
            && ok "sageboot.bin built" || warn "SageBoot compile failed"
    else
        warn "SageBoot submodule missing. Run 'git submodule update --init'"
    fi

    ## 1. Boot assembly
    info "Compiling RISC-V boot assembly (fallback)..."
    $CC $BM_CFLAGS $BM_DEFS \
        -I"${SCRIPT_DIR}/boot/arch/rv64" \
        -c "${SCRIPT_DIR}/boot/arch/rv64/boot.S" \
        -o "${BUILD_DIR}/boot.o" || fail "Boot assembly failed"

    ## 3. Root filesystem
    info "Building root filesystem..."
    "${SCRIPT_DIR}/tools/build_tools.sh" > /dev/null 2>&1 || true
    "${SCRIPT_DIR}/tools/mkrootfs.sh" "${SCRIPT_DIR}/rootfs" "${BUILD_DIR}/rootfs.bin" > /dev/null
    local rootfs_obj="${BUILD_DIR}/rootfs_obj.o"
    $OBJCOPY -I binary -O elf64-littleriscv -B riscv \
        --rename-section .data=.rootfs \
        --set-section-flags .rootfs=alloc,load,readonly \
        "${BUILD_DIR}/rootfs.bin" "${rootfs_obj}" \
        && ok "rootfs embedded" || fail "objcopy embed failed for rootfs"

    ## 3.1 Embed AIC8800 firmware
    local aic_fw_obj=""
    if [ -f "${SCRIPT_DIR}/drivers/wifi/firmware/aic8800_fw.bin" ]; then
        info "Embedding AIC8800 firmware..."
        aic_fw_obj="${BUILD_DIR}/aic8800_fw_obj.o"
        $OBJCOPY -I binary -O elf64-littleriscv -B riscv \
            --rename-section .data=.aic_fw \
            --set-section-flags .aic_fw=alloc,load,readonly \
            "${SCRIPT_DIR}/drivers/wifi/firmware/aic8800_fw.bin" "${aic_fw_obj}" \
            && ok "aic8800 firmware embedded" || fail "objcopy embed failed for aic8800_fw"
    fi

    ## 2. Compile .sgvm blobs
    compile_kernel_sgvm
    compile_shell_sgvm

    ## 3. Embed blobs (skip if SageVM disabled)
    local kernel_sgvm_obj="" shell_sgvm_obj=""
if [ "${SAGEVM_ENABLED:-0}" = "1" ]; then
        kernel_sgvm_obj=$(embed_kernel_sgvm)
        shell_sgvm_obj=$(embed_shell_sgvm)
    fi

    ## 4. RTOS (C/asm bridge)
    if rtos_available; then
        compile_rtos
    fi
    ## 5. MetalVM
    METAL_OBJS=()
    compile_metalvm

    ## 6. Kernel C entry
    info "Compiling kernel entry (fallback_kernel.c)..."
    local rtos_defs="" rtos_inc=""
    rtos_available && rtos_defs="-DSAGE_RTOS" && rtos_inc="-I${RTOS_DIR}/src/rv64" || true
    $CC $BM_CFLAGS $BM_DEFS $rtos_defs \
        -I"${KERNEL_INC}" -I"${KERNEL_VM}" -I"${KERNEL_HW}" \
        -I"${SCRIPT_DIR}/rtos" \
        $rtos_inc \
        -DCONFIG_BOARD=\"${BOARD}\" \
        -c "${SCRIPT_DIR}/kernel/hw/fallback_kernel.c" \
        -o "${BUILD_DIR}/kernel.o" || fail "Kernel C compile failed"

    info "Compiling DTB parser..."
    $CC $BM_CFLAGS -I"${KERNEL_INC}" -I"${KERNEL_HW}" \
        -c "${SCRIPT_DIR}/kernel/hw/dtb.c" \
        -o "${BUILD_DIR}/dtb.o" || fail "DTB compile failed"

    info "Compiling VMM..."
    $CC $BM_CFLAGS -I"${KERNEL_INC}" -I"${KERNEL_HW}" \
        -c "${SCRIPT_DIR}/kernel/hw/vmm.c" \
        -o "${BUILD_DIR}/vmm.o" || fail "VMM compile failed"

    ## 7. Drivers
    info "Compiling drivers..."
    while IFS= read -r -d '' sage_file; do
        local name; name=$(basename "$sage_file" .sage)
        if "$SAGEVM" compile "$sage_file" "${BUILD_DIR}/drv_${name}.sgvm" --riscv 2>/dev/null; then
            ok "Driver compiled: $name"
        fi
    done < <(find "${SCRIPT_DIR}/drivers" -name "*.sage" -print0)

    ## 7.1 SageFS Driver
    if [ -f "${SCRIPT_DIR}/fs/sagefs/src/all.sage" ]; then
        if "$SAGEVM" compile "${SCRIPT_DIR}/fs/sagefs/src/all.sage" "${BUILD_DIR}/drv_sagefs.sgvm" --riscv 2>/dev/null; then
            ok "Driver compiled: sagefs"
        else
            warn "Failed to compile sagefs driver"
        fi
    fi

    ## 7.2 SageSMP Protocol Driver
    if [ -f "${SCRIPT_DIR}/kernel/smp/src/sage/all.sage" ]; then
        if "$SAGEVM" compile "${SCRIPT_DIR}/kernel/smp/src/sage/all.sage" "${BUILD_DIR}/drv_smp.sgvm" --riscv 2>/dev/null; then
            ok "Driver compiled: smp"
        else
            warn "Failed to compile smp driver"
        fi
    fi

    ## 8. Link
    info "Linking kernel image..."
    local link_script="${SCRIPT_DIR}/boot/arch/rv64/linker.ld"
    if [ "$BOARD" = "licheerv-nano" ]; then
        link_script="${SCRIPT_DIR}/boot/arch/rv64/linker-licheerv.ld"
    fi

    local rtos_objs=()
    if rtos_available; then
        for f in sagertos_rv64.o sagertos_rv64_asm.o sagertos_glue.o; do
            [ -f "${BUILD_DIR}/${f}" ] && rtos_objs+=("${BUILD_DIR}/${f}")
        done
    fi

    local sgvm_objs=""
    if [ -n "$kernel_sgvm_obj" ]; then sgvm_objs="$kernel_sgvm_obj"; fi
    if [ -n "$shell_sgvm_obj" ]; then sgvm_objs="$sgvm_objs $shell_sgvm_obj"; fi

    local extra_objs=""
    if [ -n "$aic_fw_obj" ]; then extra_objs="$aic_fw_obj"; fi

    $LD -T "$link_script" -nostdlib \
        "${BUILD_DIR}/boot.o" \
        "${BUILD_DIR}/kernel.o" \
        "${BUILD_DIR}/dtb.o" \
        "${BUILD_DIR}/vmm.o" \
        "${METAL_OBJS[@]}" \
        "${rtos_objs[@]}" \
        $sgvm_objs \
        $extra_objs \
        "${rootfs_obj}" \
        -o "${BUILD_DIR}/sageos.elf" 2>&1 \
        && ok "Linked sageos.elf" || fail "Link failed"

    $OBJCOPY -O binary "${BUILD_DIR}/sageos.elf" "${IMAGE_DIR}/sageos.bin"
    ok "Created sageos.bin"

    if [ -f "${SCRIPT_DIR}/bootloader/sageboot.bin" ]; then
        cp "${SCRIPT_DIR}/bootloader/sageboot.bin" "${IMAGE_DIR}/sageboot.bin"
        ok "Created sageboot.bin"
    fi

    printf "\n" >&2
    printf "${GREEN}  [OK]${RESET}   Bootloader: SageBoot (Unified Bootloader)\n" >&2
    printf "${GREEN}  [OK]${RESET}   RTOS: SageRTOS (pure Sage)\n" >&2
    printf "${GREEN}  [OK]${RESET}   Kernel: kmain.sgvm embedded as .sgvm_kernel\n" >&2
    printf "${GREEN}  [OK]${RESET}   Shell:  shell.sgvm  embedded as .sgvm_shell\n" >&2
    printf "\n  ${DIM}Build complete.${RESET}\n\n" >&2
}

cmd_clean() {
    info "Cleaning build artifacts..."
    rm -rf "$BUILD_DIR"
    rm -f "$IMAGE_DIR"/sageos.bin "$IMAGE_DIR"/sageos.elf
    ok "Clean"
}

cmd_qemu() {
    info "Launching QEMU ($BOARD_NAME)..."
    local kernel_elf="${BUILD_DIR}/sageos.elf"
    local kernel_bin="${IMAGE_DIR}/sageos.bin"
    local kernel_arg
    if [ -f "$kernel_elf" ]; then kernel_arg="-kernel $kernel_elf"
    elif [ -f "$kernel_bin" ]; then kernel_arg="-kernel $kernel_bin"
    else fail "No kernel image. Run './sagemake build' first."
    fi
    local machine="${QEMU_MACHINE:-virt}"
    local cpu="${QEMU_CPU:-rv64}"
    local smp="${QEMU_SMP:-1}"
    local ram="${QEMU_RAM:-128M}"
    $QEMU -machine "$machine" -cpu "$cpu" -smp "$smp" -m "$ram" \
        -display none -chardev stdio,id=char0,mux=off \
        -serial chardev:char0 -bios "$OPENSBI" $kernel_arg 2>&1 || true
}

cmd_flash() {
    info "Flash image for $BOARD_NAME..."
    local img="${IMAGE_DIR}/sageos.bin"
    [ -f "$img" ] || fail "No image. Run './sagemake build' first."
    local dev="${SD_DEVICE:-/dev/mmcblk0}"
    info "Writing $img to $dev..."
    info "(Requires root. Use: sudo ./sagemake flash)"
    sudo dd if="$img" of="$dev" bs=1M conv=fsync status=progress \
        && ok "Flashed to $dev" || fail "Flash failed"
}

cmd_build_run() { cmd_build; cmd_qemu; }

cmd_image() {
    mkdir -p "$IMAGE_DIR"
    [ -f "${IMAGE_DIR}/sageos.bin" ] || fail "No kernel binary. Run './sagemake build' first."
    dd if=/dev/zero of="${IMAGE_DIR}/sageos.img" bs=1M count=64 2>/dev/null
    ok "Created 64MB sageos.img"
}

cmd_test() {
    for test_file in "${SCRIPT_DIR}"/tests/*.sage; do
        [ -f "$test_file" ] || continue
        local name; name=$(basename "$test_file")
        printf "  ${CYAN}%-30s${RESET}" "$name"
        "$SAGEVM" run "$test_file" > /dev/null 2>&1 \
            && printf "${GREEN}PASS${RESET}\n" \
            || printf "${RED}FAIL${RESET}\n"
    done
}

cmd_version() {
    local ver; ver=$(cat "${SCRIPT_DIR}/VERSION" 2>/dev/null || echo "unknown")
    printf "SageOS-RV version %s\nBoard: %s\nArch: %s\n" "$ver" "$BOARD" "$ARCH"
    rtos_available && echo "SageRTOS: present (${RTOS_DIR})" || echo "SageRTOS: not initialised"
    "$SAGEVM" --version 2>/dev/null || true
    $QEMU --version 2>/dev/null | head -1 || true
}

cmd_mermaid_graphics() {
    info "Generating README.md Mermaid diagrams as PNGs (mobile-friendly graphics)..."
    local svg_file="${SCRIPT_DIR}/assets/architecture.svg"
    local png_file="${SCRIPT_DIR}/assets/architecture.png"
    local cpp_file="${SCRIPT_DIR}/assets/compilation_flow.svg"
    local cpp_png="${SCRIPT_DIR}/assets/compilation_flow.png"
    local repo_file="${SCRIPT_DIR}/assets/repository_layout.svg"
    local repo_png="${SCRIPT_DIR}/assets/repository_layout.png"

    # Generate architecture diagram
    if [ -f "${SCRIPT_DIR}/assets/architecture.mmd" ]; then
        npx @mermaid-js/mermaid-cli -i "${SCRIPT_DIR}/assets/architecture.mmd" -o "${svg_file}" -e png 2>&1 \
            && ok "Generated architecture.png" || fail "architecture.svg generation failed"
    else
        warn "architecture.mmd not found, skipping"
    fi

    # Generate compilation flow diagram
    if [ -f "${SCRIPT_DIR}/assets/compilation_flow.mmd" ]; then
        npx @mermaid-js/mermaid-cli -i "${SCRIPT_DIR}/assets/compilation_flow.mmd" -o "${cpp_file}" -e png 2>&1 \
            && ok "Generated compilation_flow.png" || fail "compilation_flow.svg generation failed"
    else
        warn "compilation_flow.mmd not found, skipping"
    fi

    # Generate repository layout diagram
    if [ -f "${SCRIPT_DIR}/assets/repository_layout.mmd" ]; then
        npx @mermaid-js/mermaid-cli -i "${SCRIPT_DIR}/assets/repository_layout.mmd" -o "${repo_file}" -e png 2>&1 \
            && ok "Generated repository_layout.png" || fail "repository_layout.svg generation failed"
    else
        warn "repository_layout.mmd not found, skipping"
    fi

    ok "Mermaid graphics generation complete. PNGs are ready for mobile display in README.md"
}

cmd_help() { sed -n '2,/^$/p' "$0" | sed 's/^## \?//'; }

case "${1:-help}" in
    build)           cmd_build ;;
    clean)           cmd_clean ;;
    qemu)            cmd_qemu ;;
    build-run)       cmd_build_run ;;
    flash)           cmd_flash ;;
    image)           cmd_image ;;
    test)            cmd_test ;;
    version)         cmd_version ;;
    compile-kernel)  cmd_compile_kernel ;;
    run-kernel)      cmd_run_kernel ;;
    compile-shell)   cmd_compile_shell ;;
    run-shell)       cmd_run_shell ;;
    setup-srvm)      cmd_setup_srvm ;;
    setup-metalvm)   cmd_setup_metalvm ;;
    setup-rtos)      cmd_setup_rtos ;;
    mermaid-graphics) cmd_mermaid_graphics ;;
    help|--help|-h)  cmd_help ;;
    *)               echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac