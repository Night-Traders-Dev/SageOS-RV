#!/usr/bin/env bash
set -euo pipefail

## sagemake — SageOS-RV build system
## Usage: ./sagemake <command> [options]
##
## Commands:
##   build       Compile boot, kernel, and produce OS image
##   clean       Remove all build artifacts
##   qemu        Run OS in QEMU emulator
##   build-run   Build then run in QEMU
##   image       Generate disk image
##   flash       Flash image to SD card (requires device path)
##   test        Run test suite
##   bench       Run benchmarks
##   version     Show version info
##   help        Show this help

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/config/build.conf"

SAGE="${SAGE:-sage}"
CC="${RISCV_CC:-riscv64-linux-gnu-gcc}"
LD="${RISCV_LD:-riscv64-linux-gnu-ld}"
OBJCOPY="${RISCV_OBJCOPY:-riscv64-linux-gnu-objcopy}"
QEMU="${QEMU_BIN:-qemu-system-riscv64}"
OPENSBI="${OPENSBI_FW:-/usr/lib/riscv64-linux-gnu/opensbi/generic/fw_dynamic.bin}"

ARCH="rv64"
BOARD="${BOARD:-qemu-virt}"
BUILD_DIR="${SCRIPT_DIR}/build"
IMAGE_DIR="${SCRIPT_DIR}/images"

## Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
DIM='\033[0;90m'
BOLD='\033[1m'
RESET='\033[0m'

info()  { printf "${CYAN}  [INFO]${RESET} %s\n" "$1"; }
ok()    { printf "${GREEN}  [OK]${RESET}   %s\n" "$1"; }
warn()  { printf "${YELLOW}  [WARN]${RESET} %s\n" "$1"; }
fail()  { printf "${RED}  [FAIL]${RESET} %s\n" "$1"; exit 1; }

cmd_build() {
    printf "\n${BOLD}  SageOS-RV Build${RESET}\n"
    printf "  ${DIM}Board: %s | Arch: %s${RESET}\n\n" "$BOARD" "$ARCH"

    mkdir -p "$BUILD_DIR" "$IMAGE_DIR"

    ## Step 1: Generate boot assembly from Sage
    info "Generating boot assembly from Sage..."
    if ! $SAGE --emit-c "${SCRIPT_DIR}/boot/start.sage" -o "${BUILD_DIR}/boot_generated.c" 2>/dev/null; then
        warn "Sage boot emit failed, using fallback C"
    fi

    ## Step 2: Compile RISC-V boot assembly
    info "Compiling RISC-V boot assembly..."
    $CC -march=rv64imac_zicsr_zifencei -mabi=lp64 -nostdlib -ffreestanding \
        -c "${SCRIPT_DIR}/boot/arch/rv64/boot.S" \
        -o "${BUILD_DIR}/boot.o" || fail "Boot assembly compilation failed"

    ## Step 3: Compile kernel
    info "Compiling kernel from Sage to C..."
    if ! $SAGE --emit-c "${SCRIPT_DIR}/kernel/kmain.sage" -o "${BUILD_DIR}/kernel.c" 2>/dev/null; then
        warn "Sage kernel emit failed, using fallback"
        cp "${SCRIPT_DIR}/kernel/fallback_kernel.c" "${BUILD_DIR}/kernel.c" 2>/dev/null || true
    fi

    info "Compiling kernel C to object..."
    $CC -march=rv64imac_zicsr_zifencei -mabi=lp64 -nostdlib -ffreestanding -O2 \
        -I"${SCRIPT_DIR}/kernel" \
        -DCONFIG_BOARD=\"${BOARD}\" \
        -c "${BUILD_DIR}/kernel.c" \
        -o "${BUILD_DIR}/kernel.o" 2>&1 || warn "Kernel C compilation had issues"

    ## Step 4: Compile drivers
    info "Compiling drivers..."
    for sage_file in "${SCRIPT_DIR}"/drivers/*.sage; do
        local name=$(basename "$sage_file" .sage)
        if $SAGE --emit-c "$sage_file" -o "${BUILD_DIR}/drv_${name}.c" 2>/dev/null; then
            $CC -march=rv64imac_zicsr_zifencei -mabi=lp64 -nostdlib -ffreestanding -O2 \
                -c "${BUILD_DIR}/drv_${name}.c" -o "${BUILD_DIR}/drv_${name}.o" 2>/dev/null \
                && ok "Driver: $name" || warn "Driver: $name (partial)"
        fi
    done

    ## Step 5: Link
    info "Linking kernel image..."
    local link_script="${SCRIPT_DIR}/boot/arch/rv64/linker.ld"
    local drv_objs=()
    for f in ${BUILD_DIR}/drv_*.o; do
        [ -f "$f" ] && drv_objs+=("$f")
    done
    $LD -T "$link_script" -nostdlib \
        "${BUILD_DIR}/boot.o" \
        "${BUILD_DIR}/kernel.o" \
        "${drv_objs[@]}" \
        -o "${BUILD_DIR}/sageos.elf" 2>&1 \
        && ok "Linked sageos.elf" || warn "Link had issues (expected for alpha)"

    ## Step 6: Create binary
    if [ -f "${BUILD_DIR}/sageos.elf" ]; then
        $OBJCOPY -O binary "${BUILD_DIR}/sageos.elf" "${IMAGE_DIR}/sageos.bin"
        ok "Created sageos.bin"
    fi

    printf "\n  ${DIM}Build complete.${RESET}\n\n"
}

cmd_clean() {
    info "Cleaning build artifacts..."
    rm -rf "$BUILD_DIR"
    rm -f "$IMAGE_DIR"/sageos.bin "$IMAGE_DIR"/sageos.elf
    ok "Clean"
}

cmd_qemu() {
    info "Launching QEMU (RISC-V 64 virt)..."
    local kernel_bin="${IMAGE_DIR}/sageos.bin"
    local kernel_elf="${BUILD_DIR}/sageos.elf"

    local kernel_arg=""
    if [ -f "$kernel_elf" ]; then
        kernel_arg="-kernel $kernel_elf"
    elif [ -f "$kernel_bin" ]; then
        kernel_arg="-kernel $kernel_bin"
    else
        fail "No kernel image found. Run './sagemake build' first."
    fi

    $QEMU \
        -machine virt \
        -cpu rv64 \
        -smp 1 \
        -m 128M \
        -nographic \
        -bios "$OPENSBI" \
        $kernel_arg \
        -serial mon:stdio 2>&1 || true
}

cmd_build_run() {
    cmd_build
    cmd_qemu
}

cmd_image() {
    info "Generating disk image..."
    mkdir -p "$IMAGE_DIR"
    ## Create a minimal FAT32 image with the kernel
    if [ -f "${IMAGE_DIR}/sageos.bin" ]; then
        dd if=/dev/zero of="${IMAGE_DIR}/sageos.img" bs=1M count=64 2>/dev/null
        ok "Created 64MB disk image (sageos.img)"
    else
        fail "No kernel binary found. Run './sagemake build' first."
    fi
}

cmd_test() {
    info "Running test suite..."
    for test_file in "${SCRIPT_DIR}"/tests/*.sage; do
        local name=$(basename "$test_file")
        printf "  ${CYAN}%-30s${RESET}" "$name"
        if $SAGE --runtime ast "$test_file" > /dev/null 2>&1; then
            printf "${GREEN}PASS${RESET}\n"
        else
            printf "${RED}FAIL${RESET}\n"
        fi
    done
}

cmd_version() {
    local ver=$(cat "${SCRIPT_DIR}/VERSION" 2>/dev/null || echo "unknown")
    printf "SageOS-RV version %s\n" "$ver"
    printf "Board: %s\n" "$BOARD"
    printf "Arch: %s\n" "$ARCH"
    $SAGE --version 2>/dev/null || true
    $QEMU --version 2>/dev/null | head -1 || true
}

cmd_help() {
    sed -n '2,/^$/p' "$0" | sed 's/^## \?//'
}

case "${1:-help}" in
    build)      cmd_build ;;
    clean)      cmd_clean ;;
    qemu)       cmd_qemu ;;
    build-run)  cmd_build_run ;;
    image)      cmd_image ;;
    test)       cmd_test ;;
    version)    cmd_version ;;
    help|--help|-h) cmd_help ;;
    *)          echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac
