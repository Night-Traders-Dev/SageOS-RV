#!/usr/bin/env bash
set -euo pipefail

## sagemake - SageOS-RV build system
## Usage: ./sagemake <command> [options]
##
## Commands:
##   build           Compile boot, kernel, RTOS, MetalVM and produce OS image
##   clean           Remove all build artifacts
##   qemu            Run OS in QEMU emulator
##   build-run       Build then run in QEMU
##   image           Generate disk image
##   test            Run test suite
##   version         Show version info
##   compile-kernel  Compile kernel/kmain.sage -> kernel/kmain.sgvm
##   run-kernel      Run kernel/kmain.sgvm via sagevm
##   compile-shell   Compile shell/shell.sage -> shell/shell.sgvm
##   run-shell       Run shell/shell.sgvm via sagevm
##   setup-srvm      Copy SRVM Sage sources from SageVM repo into kernel/
##   setup-metalvm   Copy MetalVM C sources from SageLang into kernel/
##   setup-rtos      Clone rtos/SageRTOS (idempotent)
##   help            Show this help

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/config/build.conf"

## SageLang compiler
SAGE="${SAGE:-}"
if [ -z "$SAGE" ]; then
    for candidate in \
        /home/kraken/Devel/SageLang/core/build/sage \
        /home/kraken/Devel/SageLang/core/sage \
        sage sage3; do
        if command -v "$candidate" >/dev/null 2>&1 || [ -x "$candidate" ]; then
            SAGE="$candidate"; break
        fi
    done
fi
SAGE="${SAGE:-sage}"

## SageVM binary
SAGEVM="${SAGEVM:-}"
if [ -z "$SAGEVM" ]; then
    for candidate in \
        sagevm \
        /home/kraken/Devel/SageVM/sagevm \
        /home/kraken/Devel/SageLang/sagevm \
        "${SCRIPT_DIR}/../SageVM/sagevm"; do
        if command -v "$candidate" >/dev/null 2>&1 || [ -x "$candidate" ]; then
            SAGEVM="$candidate"; break
        fi
    done
fi
SAGEVM="${SAGEVM:-sagevm}"

CC="${RISCV_CC:-riscv64-linux-gnu-gcc}"
LD="${RISCV_LD:-riscv64-linux-gnu-ld}"
OBJCOPY="${RISCV_OBJCOPY:-riscv64-linux-gnu-objcopy}"
QEMU="${QEMU_BIN:-qemu-system-riscv64}"
OPENSBI="${OPENSBI_FW:-/usr/lib/riscv64-linux-gnu/opensbi/generic/fw_dynamic.bin}"

SAGEVM_DIR="${SAGEVM_DIR:-${SCRIPT_DIR}/../SageVM}"
SAGELANG_CORE="${SAGELANG_CORE:-${SCRIPT_DIR}/../SageLang/core}"
RTOS_DIR="${SCRIPT_DIR}/rtos/SageRTOS"
SAGERTOS_REPO="https://github.com/Night-Traders-Dev/SageRTOS.git"

ARCH="rv64"
BOARD="${BOARD:-qemu-virt}"
BUILD_DIR="${SCRIPT_DIR}/build"
IMAGE_DIR="${SCRIPT_DIR}/images"

## Bare-metal compile flags
BM_CFLAGS="-march=rv64imac_zicsr_zifencei -mabi=lp64 -nostdlib -ffreestanding -O2"
BM_DEFS="-DSAGE_BARE_METAL"

## Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
YELLOW='\033[1;33m'; DIM='\033[0;90m'; BOLD='\033[1m'; RESET='\033[0m'
info() { printf "${CYAN}  [INFO]${RESET} %s\n" "$1" >&2; }
ok()   { printf "${GREEN}  [OK]${RESET}   %s\n" "$1" >&2; }
warn() { printf "${YELLOW}  [WARN]${RESET} %s\n" "$1" >&2; }
fail() { printf "${RED}  [FAIL]${RESET} %s\n" "$1" >&2; exit 1; }

## Re-print ok/warn/fail to stdout for the build summary lines
## (the summary block in cmd_build uses direct printf, not these helpers)

sagevm_check() { command -v "$SAGEVM" >/dev/null 2>&1 || [ -x "$SAGEVM" ]; }

## ---------------------------------------------------------------------------
## RTOS helpers
## ---------------------------------------------------------------------------
rtos_available() {
    [ -f "${RTOS_DIR}/src/rv64/sagertos_rv64.c" ]
}

cmd_setup_rtos() {
    mkdir -p "${SCRIPT_DIR}/rtos"

    if [ -d "${RTOS_DIR}/.git" ]; then
        ok "rtos/SageRTOS already present ($(git -C "${RTOS_DIR}" rev-parse --short HEAD 2>/dev/null || echo '?'))"
        return
    fi

    [ -d "${RTOS_DIR}" ] && rm -rf "${RTOS_DIR}"

    info "Cloning SageRTOS into rtos/SageRTOS ..."
    git clone --depth=1 --branch main \
        "$SAGERTOS_REPO" \
        "${RTOS_DIR}" \
        && ok "SageRTOS cloned to rtos/SageRTOS" \
        || fail "Clone failed -- check network or repo: ${SAGERTOS_REPO}"

    rtos_available \
        && ok "SageRTOS ready: ${RTOS_DIR}" \
        || warn "Cloned but sagertos_rv64.c not found -- check repo structure"
}

compile_rtos() {
    if ! rtos_available; then
        warn "SageRTOS not found at ${RTOS_DIR} -- skipping RTOS compilation"
        warn "  Run: ./sagemake setup-rtos"
        return
    fi

    info "Compiling SageRTOS RV64 (sagertos_rv64.c)..."
    $CC $BM_CFLAGS $BM_DEFS -DSAGE_RTOS \
        -I"${RTOS_DIR}/src/rv64" \
        -c "${RTOS_DIR}/src/rv64/sagertos_rv64.c" \
        -o "${BUILD_DIR}/sagertos_rv64.o" \
        && ok "sagertos_rv64.o" || warn "sagertos_rv64.c compile had warnings"

    info "Compiling SageRTOS RV64 (sagertos_rv64_asm.S)..."
    $CC $BM_CFLAGS \
        -I"${RTOS_DIR}/src/rv64" \
        -c "${RTOS_DIR}/src/rv64/sagertos_rv64_asm.S" \
        -o "${BUILD_DIR}/sagertos_rv64_asm.o" \
        && ok "sagertos_rv64_asm.o" || warn "asm compile had warnings"

    info "Compiling RTOS glue (rtos/sagertos_glue.c)..."
    $CC $BM_CFLAGS $BM_DEFS -DSAGE_RTOS \
        -I"${RTOS_DIR}/src/rv64" \
        -I"${SCRIPT_DIR}/kernel" \
        -c "${SCRIPT_DIR}/rtos/sagertos_glue.c" \
        -o "${BUILD_DIR}/sagertos_glue.o" \
        && ok "sagertos_glue.o" || warn "glue compile had warnings"
}

## ---------------------------------------------------------------------------
## sgvm helpers
## ---------------------------------------------------------------------------
compile_kernel_sgvm() {
    local src="${SCRIPT_DIR}/kernel/kmain.sage"
    local out="${SCRIPT_DIR}/kernel/kmain.sgvm"
    [ -f "${src}" ] || { warn "kernel/kmain.sage not found"; return; }
    sagevm_check || { warn "sagevm not found -- skipping kmain.sgvm"; return; }
    info "Compiling kernel/kmain.sage -> kernel/kmain.sgvm ..."
    if "$SAGEVM" compile "${src}" "${out}" --riscv 2>&1; then
        ok "kmain.sgvm ($(wc -c < "${out}") bytes)"
    else
        warn "sagevm compile kernel failed"
    fi
}

compile_shell_sgvm() {
    local src="${SCRIPT_DIR}/shell/shell.sage"
    local out="${SCRIPT_DIR}/shell/shell.sgvm"
    [ -f "${src}" ] || fail "shell/shell.sage not found -- cannot build without shell"
    sagevm_check || fail "sagevm not found -- cannot compile shell.sgvm"
    info "Compiling shell/shell.sage -> shell/shell.sgvm ..."
    if "$SAGEVM" compile "${src}" "${out}" --riscv 2>&1; then
        ok "shell.sgvm ($(wc -c < "${out}") bytes)"
    else
        fail "shell/shell.sage compilation failed -- fix shell.sage before building"
    fi
}

## ---------------------------------------------------------------------------
## embed_shell_sgvm
##
## CRITICAL: all output except the final object-file path goes to stderr.
## The function is called as:  sgvm_obj=$(embed_shell_sgvm)
## so ONLY the path echoed at the very end must appear on stdout.
## ---------------------------------------------------------------------------
embed_shell_sgvm() {
    local src="${SCRIPT_DIR}/shell/shell.sgvm"
    local obj="${BUILD_DIR}/shell_sgvm.o"

    ## shell.sgvm must exist at this point -- compile_shell_sgvm() above
    ## already called fail() if it couldn't produce it.
    if [ ! -f "${src}" ]; then
        fail "embed_shell_sgvm: ${src} missing after compile step -- aborting"
    fi

    local bsz
    bsz=$(wc -c < "${src}")
    info "Embedding shell/shell.sgvm (${bsz} bytes) into .sgvm_shell section..." >&2

    $OBJCOPY \
        -I binary -O elf64-littleriscv -B riscv \
        --rename-section .data=.sgvm_shell \
        --set-section-flags .sgvm_shell=alloc,load,readonly \
        "${src}" "${obj}" \
        && ok "shell_sgvm.o embedded (${bsz} bytes)" \
        || fail "objcopy embed failed for shell.sgvm"

    ## Patch SGVM_SECTION_SIZE in build/kernel.c so Sage code sees the
    ## real blob size at runtime.
    if [ -f "${BUILD_DIR}/kernel.c" ]; then
        sed -i "s/let SGVM_SECTION_SIZE = 0/let SGVM_SECTION_SIZE = ${bsz}/g" \
            "${BUILD_DIR}/kernel.c" 2>/dev/null || true
    fi

    ## stdout: ONLY the object file path
    echo "${obj}"
}

cmd_ensure_srvm() {
    local srvm_src="${SAGEVM_DIR}/src/srvm"
    local kdir="${SCRIPT_DIR}/kernel"
    [ -f "${kdir}/srvm_core.sage" ] && [ -f "${kdir}/srvm_vm.sage" ] && return 0
    if [ -d "${srvm_src}" ]; then
        info "Copying SRVM sources..."
        cp "${srvm_src}/srvm_core.sage" "${kdir}/srvm_core.sage"
        cp "${srvm_src}/srvm_vm.sage"   "${kdir}/srvm_vm.sage"
        ok "SRVM staged in kernel/"
    else
        warn "SAGEVM_DIR not found (${SAGEVM_DIR}). Set SAGEVM_DIR or run './sagemake setup-srvm'."
    fi
}

cmd_setup_srvm() {
    local srvm_src="${SAGEVM_DIR}/src/srvm"
    [ -d "${srvm_src}" ] || fail "SageVM not found at ${SAGEVM_DIR}. Set SAGEVM_DIR."
    cp "${srvm_src}/srvm_core.sage" "${SCRIPT_DIR}/kernel/srvm_core.sage"
    cp "${srvm_src}/srvm_vm.sage"   "${SCRIPT_DIR}/kernel/srvm_vm.sage"
    ok "kernel/srvm_core.sage"; ok "kernel/srvm_vm.sage"
}

cmd_compile_kernel() { compile_kernel_sgvm; }
cmd_run_kernel() {
    local sgvm="${SCRIPT_DIR}/kernel/kmain.sgvm"
    [ -f "${sgvm}" ] || fail "kernel/kmain.sgvm not found."
    sagevm_check || fail "sagevm not found."
    "$SAGEVM" run "${sgvm}"
}
cmd_compile_shell() { mkdir -p "${SCRIPT_DIR}/shell"; compile_shell_sgvm; }
cmd_run_shell() {
    local sgvm="${SCRIPT_DIR}/shell/shell.sgvm"
    [ -f "${sgvm}" ] || fail "shell/shell.sgvm not found."
    sagevm_check || fail "sagevm not found."
    "$SAGEVM" run "${sgvm}"
}

cmd_setup_metalvm() {
    local src_c="${SAGELANG_CORE}/core/metal_vm.c"
    local src_rv="${SAGELANG_CORE}/core/metal_rv64_vm.c"
    local src_h="${SAGELANG_CORE}/core/metal_vm.h"
    local src_rvh="${SAGELANG_CORE}/core/metal_rv64_vm.h"
    local dst="${SCRIPT_DIR}/kernel"
    [ -f "${src_c}" ]  || fail "metal_vm.c not found at ${src_c}. Set SAGELANG_CORE."
    cp "${src_c}"   "${dst}/metal_vm_bundled.c"
    cp "${src_rv}"  "${dst}/metal_rv64_vm_bundled.c"
    cp "${src_h}"   "${dst}/metal_vm.h"
    cp "${src_rvh}" "${dst}/metal_rv64_vm.h"
    ok "MetalVM sources bundled into kernel/"
}

## ---------------------------------------------------------------------------
## cmd_build
## ---------------------------------------------------------------------------
cmd_build() {
    printf "\n${BOLD}  SageOS-RV Build${RESET}\n" >&2
    printf "  ${DIM}Board: %s | Arch: %s${RESET}\n\n" "$BOARD" "$ARCH" >&2
    mkdir -p "$BUILD_DIR" "$IMAGE_DIR"

    cmd_ensure_srvm

    ## 1. Boot assembly
    info "Generating boot assembly from Sage..."
    $SAGE --emit-c "${SCRIPT_DIR}/boot/start.sage" \
        -o "${BUILD_DIR}/boot_generated.c" 2>/dev/null \
        || warn "Sage boot emit failed (boot.S used directly)"

    info "Compiling RISC-V boot assembly..."
    $CC $BM_CFLAGS \
        -c "${SCRIPT_DIR}/boot/arch/rv64/boot.S" \
        -o "${BUILD_DIR}/boot.o" || fail "Boot assembly failed"

    ## 2. Sage bytecode -- shell MUST succeed (fail() on error)
    compile_kernel_sgvm
    compile_shell_sgvm

    ## 3. Embed shell.sgvm -- stdout ONLY returns the .o path
    local sgvm_obj
    sgvm_obj=$(embed_shell_sgvm)

    ## 4. RTOS
    compile_rtos

    ## 5. Kernel C (from Sage transpiler) -- MUST succeed; no fallback
    info "Compiling kernel from Sage to C..."
    if ! $SAGE --emit-c "${SCRIPT_DIR}/kernel/kmain.sage" \
            -o "${BUILD_DIR}/kernel.c" 2>/dev/null; then
        fail "Sage kernel emit failed -- fix kernel/kmain.sage before building (no C fallback)"
    fi

    ## Patch SGVM_SECTION_SIZE into the transpiled kernel.c
    local bsz
    bsz=$(wc -c < "${SCRIPT_DIR}/shell/shell.sgvm")
    sed -i "s/SGVM_SECTION_SIZE = 0/SGVM_SECTION_SIZE = ${bsz}/g" \
        "${BUILD_DIR}/kernel.c" 2>/dev/null || true

    local rtos_defs="" rtos_inc=""
    if rtos_available; then
        rtos_defs="-DSAGE_RTOS"
        rtos_inc="-I${RTOS_DIR}/src/rv64"
    fi

    info "Compiling kernel C to object..."
    $CC $BM_CFLAGS $BM_DEFS $rtos_defs \
        -I"${SCRIPT_DIR}/kernel" \
        -I"${SCRIPT_DIR}/rtos" \
        $rtos_inc \
        -DCONFIG_BOARD=\"${BOARD}\" \
        -c "${BUILD_DIR}/kernel.c" \
        -o "${BUILD_DIR}/kernel.o" 2>&1 \
        || fail "Kernel C compile failed"

    info "Compiling DTB parser..."
    $CC $BM_CFLAGS -I"${SCRIPT_DIR}/kernel" \
        -c "${SCRIPT_DIR}/kernel/dtb.c" \
        -o "${BUILD_DIR}/dtb.o" || fail "DTB compile failed"

    info "Compiling VMM..."
    $CC $BM_CFLAGS -I"${SCRIPT_DIR}/kernel" \
        -c "${SCRIPT_DIR}/kernel/vmm.c" \
        -o "${BUILD_DIR}/vmm.o" || fail "VMM compile failed"

    ## 6. Drivers
    info "Compiling drivers..."
    for sage_file in "${SCRIPT_DIR}"/drivers/*.sage; do
        [ -f "$sage_file" ] || continue
        local name; name=$(basename "$sage_file" .sage)
        if $SAGE --emit-c "$sage_file" -o "${BUILD_DIR}/drv_${name}.c" 2>/dev/null; then
            $CC $BM_CFLAGS -c "${BUILD_DIR}/drv_${name}.c" \
                -o "${BUILD_DIR}/drv_${name}.o" 2>/dev/null \
                && ok "Driver: $name" || warn "Driver: $name (partial)"
        fi
    done

    ## 7. Link
    info "Linking kernel image..."
    local link_script="${SCRIPT_DIR}/boot/arch/rv64/linker.ld"
    local drv_objs=()
    for f in "${BUILD_DIR}"/drv_*.o; do [ -f "$f" ] && drv_objs+=("$f"); done

    local rtos_objs=()
    if rtos_available; then
        for f in sagertos_rv64.o sagertos_rv64_asm.o sagertos_glue.o; do
            [ -f "${BUILD_DIR}/${f}" ] && rtos_objs+=("${BUILD_DIR}/${f}")
        done
    fi

    local extra_objs=()
    [ -f "${sgvm_obj}" ] && extra_objs+=("${sgvm_obj}")

    $LD -T "$link_script" -nostdlib \
        "${BUILD_DIR}/boot.o" \
        "${BUILD_DIR}/kernel.o" \
        "${BUILD_DIR}/dtb.o" \
        "${BUILD_DIR}/vmm.o" \
        "${rtos_objs[@]}" \
        "${extra_objs[@]}" \
        "${drv_objs[@]}" \
        -o "${BUILD_DIR}/sageos.elf" 2>&1 \
        && ok "Linked sageos.elf" || fail "Link failed"

    $OBJCOPY -O binary "${BUILD_DIR}/sageos.elf" "${IMAGE_DIR}/sageos.bin"
    ok "Created sageos.bin"

    ## Build summary
    printf "\n" >&2
    rtos_available \
        && printf "${GREEN}  [OK]${RESET}   RTOS: SageRTOS RV64 linked\n" >&2 \
        || printf "${YELLOW}  [WARN]${RESET} RTOS: not linked (run ./sagemake setup-rtos)\n" >&2
    printf "${GREEN}  [OK]${RESET}   Kernel: kmain.sgvm (%s bytes, MetalVM)\n" \
        "$(wc -c < "${SCRIPT_DIR}/kernel/kmain.sgvm" 2>/dev/null || echo 0)" >&2
    printf "${GREEN}  [OK]${RESET}   Shell:  shell.sgvm (%s bytes, patched)\n" \
        "$(wc -c < "${SCRIPT_DIR}/shell/shell.sgvm" 2>/dev/null || echo 0)" >&2
    printf "\n  ${DIM}Build complete.${RESET}\n\n" >&2
}

cmd_clean() {
    info "Cleaning build artifacts..."
    rm -rf "$BUILD_DIR"
    rm -f "$IMAGE_DIR"/sageos.bin "$IMAGE_DIR"/sageos.elf
    ok "Clean"
}

cmd_qemu() {
    info "Launching QEMU (RISC-V 64 virt)..."
    local kernel_elf="${BUILD_DIR}/sageos.elf"
    local kernel_bin="${IMAGE_DIR}/sageos.bin"
    local kernel_arg
    if [ -f "$kernel_elf" ]; then kernel_arg="-kernel $kernel_elf"
    elif [ -f "$kernel_bin" ]; then kernel_arg="-kernel $kernel_bin"
    else fail "No kernel image. Run './sagemake build' first."
    fi
    $QEMU -machine virt -cpu rv64 -smp 1 -m 128M -nographic \
        -bios "$OPENSBI" $kernel_arg -serial mon:stdio 2>&1 || true
}

cmd_build_run() { cmd_build; cmd_qemu; }

cmd_image() {
    mkdir -p "$IMAGE_DIR"
    [ -f "${IMAGE_DIR}/sageos.bin" ] || fail "No kernel binary. Run './sagemake build' first."
    dd if=/dev/zero of="${IMAGE_DIR}/sageos.img" bs=1M count=64 2>/dev/null
    ok "Created 64MB sageos.img"
}

cmd_test() {
    for test_file in "${SCRIPT_DIR}"/tests/*.sage; do
        [ -f "$test_file" ] || continue
        local name; name=$(basename "$test_file")
        printf "  ${CYAN}%-30s${RESET}" "$name"
        $SAGE --runtime ast "$test_file" > /dev/null 2>&1 \
            && printf "${GREEN}PASS${RESET}\n" \
            || printf "${RED}FAIL${RESET}\n"
    done
}

cmd_version() {
    local ver; ver=$(cat "${SCRIPT_DIR}/VERSION" 2>/dev/null || echo "unknown")
    printf "SageOS-RV version %s\nBoard: %s\nArch: %s\n" "$ver" "$BOARD" "$ARCH"
    rtos_available && echo "SageRTOS: present (${RTOS_DIR})" || echo "SageRTOS: not initialised"
    $SAGE --version 2>/dev/null || true
    "$SAGEVM" --version 2>/dev/null || true
    $QEMU --version 2>/dev/null | head -1 || true
}

cmd_help() { sed -n '2,/^$/p' "$0" | sed 's/^## \?//'; }

case "${1:-help}" in
    build)           cmd_build ;;
    clean)           cmd_clean ;;
    qemu)            cmd_qemu ;;
    build-run)       cmd_build_run ;;
    image)           cmd_image ;;
    test)            cmd_test ;;
    version)         cmd_version ;;
    compile-kernel)  cmd_compile_kernel ;;
    run-kernel)      cmd_run_kernel ;;
    compile-shell)   cmd_compile_shell ;;
    run-shell)       cmd_run_shell ;;
    setup-srvm)      cmd_setup_srvm ;;
    setup-metalvm)   cmd_setup_metalvm ;;
    setup-rtos)      cmd_setup_rtos ;;
    help|--help|-h)  cmd_help ;;
    *)               echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac
