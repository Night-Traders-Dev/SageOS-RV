flowchart TD
    subgraph Sources["Source Files"]
        K1["kernel/core/kmain.sage"]
        K2["kernel/srvm/srvm_*.sage"]
        SH["shell/shell.sage"]
        T["tools/bin/*.sage<br/>(45 commands)"]
        SSH["tools/gen_ssh.sh<br/>→ tcp_stack + ssh_main<br/>= ssh.sage"]
        C1["boot/arch/rv64/boot.S"]
        C2["kernel/hw/*.c"]
        C3["kernel/vm/metal_rv64_vm_impl.c"]
    end

    subgraph Config["Build Configuration"]
        BC["config/build.conf"]
        BQ["config/boards/qemu-virt.conf"]
        BL["config/boards/licheerv-nano.conf"]
    end

    subgraph Compile["Compilation Pipeline"]
        SC1{"sagevm compile --riscv"}
        SC2{"sagevm compile --riscv"}
        SC3{"sagevm compile --riscv"}
        BT["tools/build_tools.sh<br/>(iterates tools/bin/*.sage)"]
        AS{"riscv64-linux-gnu-gcc<br/>-nostdlib -ffreestanding"}
        OBJ{"riscv64-linux-gnu-objcopy"}
        LD{"riscv64-linux-gnu-ld<br/>-T boot/arch/rv64/linker.ld"}
    end

    subgraph Artifacts["Build Artifacts"]
        SK["kmain.sgvm"]
        SS["shell.sgvm"]
        SG["rootfs/bin/*.sgvm<br/>(45 binaries incl. ssh)"]
        CO["boot.o, kernel.o, metal_vm.o, …"]
        SBIN["<b>sageos.elf</b>"]
        OBIN["<b>sageos.bin</b>"]
        RF["rootfs.bin"]
    end

    subgraph QEMU["QEMU Run"]
        Q["qemu-system-riscv64<br/>-machine virt<br/>-bios opensbi<br/>-kernel sageos.bin"]
    end

    K1 --> SC1
    K2 --> SC1
    SH --> SC2
    T --> BT
    SSH --> BT
    SC1 --> SK
    SC2 --> SS
    BT --> SG
    C1 --> AS
    C2 --> AS
    C3 --> AS
    AS --> CO
    SK --> OBJ
    SS --> OBJ
    OBJ --> LD
    CO --> LD
    LD --> SBIN
    SBIN --> OBIN
    SG --> RF
    RF --> OBIN
    
    BC --> LD
    BQ --> Q
    BL --> Q

    OBIN --> Q

