flowchart TB
    subgraph Boot["Boot Process"]
        direction TB
        SB["<b>SageBoot (Unified Bootloader)</b><br/>bootloader/src/bootloader.sage<br/><i>Arch: rv64, arm64, mips, x64, rp2040/2350</i>"]
        BL["<b>Kernel Entry</b><br/>boot/arch/rv64/boot.S<br/><i>RV64 ASM entry, linker script</i>"]
        SB --> BL
    end

    subgraph KernelImage["SageOS-RV Kernel (sageos.elf)"]
        direction TB
        
        L1["<b>Layer 1: C Kernel — Hardware Abstraction</b><br/>kernel/hw/*.c + boot/*.S<br/><i>DTB parse, SBI, VMM, fallback kernel</i>"]

        subgraph VM["SageVM Runtime (default)"]
            direction TB
            L3["<b>L3: SRVM — Sage RISC‑V VM</b><br/>kernel/srvm/srvm_vm.sage<br/><i>Compiled via sagevm --riscv</i>"]
            L2["<b>L2: MetalRV64VM — Bare‑metal C Adapter</b><br/>kernel/vm/metal_rv64_vm_impl.c<br/><i>Q32.32 fixed‑point, no libc, no FPU</i>"]
            L3 --> L2
        end

        RTOS["<b>SageRTOS</b><br/>kernel/rtos/sagertos.sage<br/><i>Pure‑Sage preemptive task scheduler</i>"]

        subgraph Subs["Kernel Subsystems (pure Sage)"]
            direction TB
            Net["<b>Network Stack</b><br/>kernel/net/tcp_stack.sage<br/>Ether→ARP→IPv4→TCP/UDP→socket API<br/><i>Transport backend: loopback / kernel</i>"]
            SSH["<b>SSH Client</b><br/>kernel/ssh/ssh_client.sage<br/>RFC 4251‑4254, SHA‑256, HMAC<br/><i>Cluster monitor</i>"]
            Drv["<b>Hardware Drivers</b><br/>drivers/{gpio,i2c,spi,uart,usb,display,wifi,sdio,sdcard}<br/><i>Board, bus, FS drivers</i>"]
            SysDrv["<b>System Drivers</b><br/>drivers/sys/{plic,timer,syscon,watchdog}<br/>kernel/hw/sdcard.sage<br/>kernel/drivers/net/virtio_net.sage"]
            FS["<b>Filesystems</b><br/>drivers/fs/{ext4,fat}<br/>fs/sagefs (CoW B‑tree)<br/>kernel/vfs.sage"]
            Crypt["<b>Crypto Library</b><br/>kernel/crypto/{sha256,hmac}.sage<br/><i>FIPS 180‑4, RFC 2104</i>"]
            SMP["<b>SageSMP</b><br/>kernel/smp (submodule)<br/><i>Multicore messaging</i>"]
            Net ~~~ SSH ~~~ Crypt
            Drv ~~~ SysDrv ~~~ FS ~~~ SMP
        end

        Embeds["<b>Embedded Sections</b><br/>.sgvm_kernel — kmain.sgvm<br/>.sgvm_shell — shell.sgvm<br/>.rootfs — 45 userspace .sgvm commands<br/>(ssh, ls, cat, cp, ping, curl, …)"]

        BL --> L1
        L1 --> VM
        VM --> RTOS
        RTOS --> Subs
        Embeds -.-> L1
    end

    subgraph QEMU["QEMU virt Target"]
        direction TB
        Q["<b>QEMU rv64 virt</b><br/>-device virtio-net-pci<br/>-netdev user,id=net0<br/><i>CLINT/PLIC, 16550A UART</i>"]
        VN["<b>virtio-net Backend</b><br/>netdev_tx / netdev_rx builtins<br/>→ g_net_tx_buf[] (C stub)"]
    end

    KernelImage --> QEMU
    Net -.-> VN

