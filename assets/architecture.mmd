flowchart TB
    subgraph Boot["Boot Process"]
        direction TB
        SB["<b>SageBoot (Unified Bootloader)</b><br/>bootloader/src/bootloader.sage<br/><i>Loads sageos.bin, sets up SAGEOSBI handoff</i>"]
    end

    subgraph KernelImage["SageOS-RV kernel image (sageos.elf)"]
        direction TB
        
        subgraph SageSubsystems["Sage Subsystems (drv_*.sgvm)"]
            direction TB
            SMP["<b>SageSMP</b><br/>Distributed Multicore Protocol"]
            FS["<b>SageFS</b><br/>Native CoW B-tree Filesystem"]
            Drivers["<b>Hardware Drivers</b><br/>SD/MMC, WiFi, USB, Display"]
            SMP ~~~ FS ~~~ Drivers
        end
        
        subgraph RTOS["Real-Time OS"]
            direction TB
            SageRTOS["<b>SageRTOS</b><br/>Pure Sage Task Scheduler<br/><i>Preemptive / Cooperative GC-aware scheduling</i>"]
        end

        subgraph SageVM["SageVM Runtime (optional, enabled by default)"]
            direction TB
            L3["<b>Layer 3: SRVM — Sage-level VM</b><br/>kernel/srvm/*.sage<br/><i>Compiled into SGRV bytecode via --riscv</i>"]
            
            L2["<b>Layer 2: MetalRV64VM — Bare-metal C adapter</b><br/>kernel/vm/metal_rv64_vm_impl.c<br/><i>Q32.32 fixed-point, no libc, no FPU</i>"]
            
            L3 --> L2
        end
        
        L1["<b>Layer 1: C kernel — Hardware abstraction</b><br/>kernel/hw/fallback_kernel.c, dtb.c, vmm.c<br/><i>UART, PMM, VMM, SBI wrappers</i>"]
        
        Embeds["<b>Embedded sections:</b><br/>.sgvm_kernel — kmain.sgvm<br/>.sgvm_shell — shell.sgvm<br/>.rootfs — rootfs.bin"]
        
        Boot --> L1
        SageSubsystems --> RTOS
        RTOS --> SageVM
        SageVM --> L1
        Embeds -.-> L1
    end
    
    style Boot fill:transparent,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style KernelImage fill:transparent,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style SageVM fill:transparent,stroke:#666,stroke-width:1.5px
    style SageSubsystems fill:transparent,stroke:#666,stroke-width:1.5px
    style RTOS fill:transparent,stroke:#666,stroke-width:1.5px
    style SB fill:#e17055,color:#fff,stroke:#fff,stroke-width:1px
    style L3 fill:#2d3436,color:#fff,stroke:#fff,stroke-width:1px
    style L2 fill:#0984e3,color:#fff,stroke:#fff,stroke-width:1px
    style L1 fill:#d63031,color:#fff,stroke:#fff,stroke-width:1px
    style Embeds fill:#00b894,color:#fff,stroke:#fff,stroke-width:1px
    style SMP fill:#6c5ce7,color:#fff,stroke:#fff,stroke-width:1px
    style FS fill:#fdcb6e,color:#333,stroke:#fff,stroke-width:1px
    style Drivers fill:#00cec9,color:#fff,stroke:#fff,stroke-width:1px
    style SageRTOS fill:#e84393,color:#fff,stroke:#fff,stroke-width:1px
