flowchart LR
    Root["<b>SageOS-RV/</b>"]
    
    Boot["<b>boot/</b><br/><i>Bare-metal entry & linker</i>"]
    Root --> Boot
    
    Root --> Kernel["<b>kernel/</b>"]
    Root --> Drivers["<b>drivers/</b>"]
    
    Shell["<b>shell/</b><br/><i>Interactive prompt</i>"]
