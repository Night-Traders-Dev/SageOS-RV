flowchart TB
    Root["<b>SageOS-RV/</b>"]

    subgraph Core["Core OS"]
        Boot["<b>boot/</b><br/>arch/rv64/{boot.S,linker.ld}<br/><i>Kernel entry</i>"]
        Bootloader["<b>bootloader/</b><br/>SageBoot submodule"]
        SM["<b>sagemake</b><br/>Build orchestration"]
        Shell["<b>shell/</b><br/>shell.sage — interactive prompt"]
    end

    subgraph KernelSub["kernel/ — SageOS Kernel"]
        K1["<b>core/</b> kmain, panic, errors"]
        K2["<b>vm/</b> metal_rv64_vm_impl.c"]
        K3["<b>srvm/</b> SRVM VM + compiler"]
        K4["<b>hw/</b> dtb.sage, sbi, vmm, sdcard"]
        K5["<b>net/</b> tcp_stack, ipv4, dhcp,<br/>dns, http, tls, udp"]
        K6["<b>crypto/</b> sha256, hmac"]
        K7["<b>ssh/</b> ssh_client,<br/>cluster_monitor"]
        K8["<b>rtos/</b> sagertos.sage"]
        K9["<b>drivers/net/</b> virtio_net.sage"]
        K10["<b>smp/</b> SageSMP submodule"]
        KX["pmm, vfs, rootfs,<br/>dmesg, interrupt,<br/>kernel_panic"]
    end

    subgraph DriversSub["drivers/ — Device Drivers"]
        D1["<b>gpio/</b> — GPIO"]
        D2["<b>bus/</b> — i2c, spi, sdio"]
        D3["<b>uart/</b> — 16550A UART"]
        D4["<b>usb/</b> — DWC2 OTG"]
        D5["<b>display/</b> — LCD/VOU"]
        D6["<b>wifi/</b> — AIC8800, ESP-AT"]
        D7["<b>fs/</b> — ext4, fat32"]
        D8["<b>sys/</b> — plic, timer, syscon, wdog"]
        D9["<b>boards/</b> — licheerv"]
    end

    subgraph SubMod["Submodules"]
        RTOS["<b>rtos/SageRTOS/</b><br/>C + Sage scheduler"]
        FSS["<b>fs/sagefs/</b><br/>CoW B-tree, 30+ modules"]
        Deps["<b>deps/SageVM/</b><br/>SageVM compiler + VM"]
    end

    subgraph Userspace["Userspace & Tooling"]
        Tools["<b>tools/bin/*.sage</b><br/>45 commands (ssh, ls, cat, cp)"]
        TScr["<b>tools/</b> build_tools.sh,<br/>gen_ssh.sh, mkrootfs.sh"]
        RFS["<b>rootfs/bin/*.sgvm</b><br/>Compiled binaries"]
    end

    subgraph ConfigDocs["Configuration & Docs"]
        Conf["<b>config/boards/</b><br/>qemu-virt, licheerv-nano"]
        Docs["<b>docs/</b> — architecture, net,<br/>ssh, drivers, kernel, …"]
        Assets["<b>assets/</b> — MMD, PNG, SVG<br/>architecture diagrams"]
        Tests["<b>tests/</b> — ssh, net, qemu,<br/>fs, wifi, shell, driver tests"]
        Images["<b>images/</b> — pre-built binaries"]
    end

    Root --> Core
    Root --> KernelSub
    Root --> DriversSub
    Root --> SubMod
    Root --> Userspace
    Root --> ConfigDocs

